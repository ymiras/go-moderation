# Dify Moderation Service Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
MODERATION_SERVER_HOST=0.0.0.0
MODERATION_SERVER_PORT=8080
MODERATION_SERVER_READ_TIMEOUT=10s
MODERATION_SERVER_WRITE_TIMEOUT=10s

# Log Configuration
MODERATION_LOG_LEVEL=info
MODERATION_LOG_ENCODING=json

# Auth Configuration (comma-separated API keys)
MODERATION_AUTH_API_KEYS=secret-key-1,secret-key-2

# Rate Limit Configuration
MODERATION_RATELIMIT_RATE=100
MODERATION_RATELIMIT_CAPACITY=200

# Moderation Configuration
MODERATION_MODERATION_PIPELINE_MODE=chain
MODERATION_MODERATION_WEIGHTED_THRESHOLD=0.5
MODERATION_MODERATION_FALLBACK_ACTION=pass

# Matcher Configuration - AC (Aho-Corasick)
MODERATION_MATCHERS_AC_ENABLED=true

# Matcher Configuration - Regex
MODERATION_MATCHERS_REGEX_ENABLED=false

# Matcher Configuration - External API
MODERATION_MATCHERS_EXTERNAL_ENABLED=false
MODERATION_MATCHERS_EXTERNAL_API_URL=
MODERATION_MATCHERS_EXTERNAL_API_KEY=
MODERATION_MATCHERS_EXTERNAL_TIMEOUT=5s
